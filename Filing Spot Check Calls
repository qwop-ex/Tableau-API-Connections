/**
 * Fetches Daily RI Audit and RTS with one Tableau sign-in.
 * Filters RTS using the fresh Daily RI Audit data in memory.
 * Writes Daily RI Audit to A2:N.
 * Writes RTS to AG2:AT.
 */
function updateAllLists() {
  return withScriptLock_(function () {
    const sheet = getSheet_(LISTS_SHEET_NAME);
    const call = getSignedTableauCall_();

    const dailyResponse = getParsedCustomViewData_(call, DAILY_RI_AUDIT_VIEW_ID);
    const dailyData = correctTableauData(dailyResponse);

    const rtsResponse = getParsedCustomViewData_(call, RTS_DATA_SOURCE_VIEW_ID);
    const rtsDataRaw = correctTableauData(rtsResponse);

    const dailyIds = getIdsFromCorrectedData_(dailyData);
    const rtsData = filterCorrectedDataByMissingIds_(rtsDataRaw, dailyIds);

    writeFixedWidthOutputFast_(
      sheet,
      DAILY_OUTPUT_ROW,
      DAILY_OUTPUT_COL,
      dailyData,
      REPORT_NUM_COLS,
      DAILY_ROW_COUNT_KEY
    );

    writeFixedWidthOutputFast_(
      sheet,
      RTS_OUTPUT_ROW,
      RTS_OUTPUT_COL,
      rtsData,
      REPORT_NUM_COLS,
      RTS_ROW_COUNT_KEY
    );
  });
}

