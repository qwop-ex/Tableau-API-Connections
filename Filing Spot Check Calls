    const rtsData = filterCorrectedDataByMissingIds_(rtsDataRaw, existingDailyIds);

    writeFixedWidthOutputFast_(
      sheet,
      RTS_OUTPUT_ROW,
      RTS_OUTPUT_COL,
      rtsData,
      REPORT_NUM_COLS,
      RTS_ROW_COUNT_KEY
    );
  });
}

