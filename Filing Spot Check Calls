/**
 * Updates only Ready to Shelve data into Lists!AG2:AT.
 */
function updateListsRTS() {
  return withScriptLock_(function () {
    const sheet = getSheet_(LISTS_SHEET_NAME);
    const call = getSignedTableauCall_();

    const responseData = getParsedCustomViewData_(call, RTS_DATA_SOURCE_VIEW_ID);
