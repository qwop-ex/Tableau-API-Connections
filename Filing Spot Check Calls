/**
 * Updates SQdata with only selected raw Tableau source columns.
 * Source Tableau columns returned: 4, 6, 7, 8.
 */
function updateSQdata() {
  return withScriptLock_(function () {
    const sheet = getSheet_(SQDATA_SHEET_NAME);
    const call = getSignedTableauCall_();

    const parsedData = getParsedCustomViewData_(call, SQ_LAST_7_DAYS_VIEW_ID);

    const sqData = selectSourceColumns_(parsedData, [4, 6, 7, 8]);

    writeVariableWidthOutputFast_(
      sheet,
      SQ_OUTPUT_ROW,
      SQ_OUTPUT_COL,
      sqData,
      SQ_ROW_COUNT_KEY,
      SQ_COL_COUNT_KEY
    );
  });
}

