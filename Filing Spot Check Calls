const LISTS_SHEET_NAME = "Lists";
const SQDATA_SHEET_NAME = "SQdata";
const RITIMESTAMP_SHEET_NAME = "RITimestamp";
const TABLEAU_TOKEN_EMAIL = 'jbleach@ebay.com'

// Tableau custom views
const DAILY_RI_AUDIT_VIEW_ID = "c2294c45-368d-4f5a-bd3f-d8cf4f7a4a3f"; //'Card Movement by Value' - Stocked
const RTS_DATA_SOURCE_VIEW_ID = "ddcbbb8d-5c07-4f9c-942f-eb283fd2cbad"; //'Card Movement by Value' - Completed
const SQ_LAST_7_DAYS_VIEW_ID = "5db52cc1-e5ae-45c6-8673-0855549d4c9b"; //'Cards in SQ' report under 'Direct Order + SQ Information'
const FILING_TRACKER_VIEW_ID = "1e218792-af1c-49e2-b73b-36b27b243c53"; //

// Output locations
const DAILY_OUTPUT_ROW = 2;
const DAILY_OUTPUT_COL = 1; // A

const RTS_OUTPUT_ROW = 2;
const RTS_OUTPUT_COL = 33; // AG

const SQ_OUTPUT_ROW = 1;
const SQ_OUTPUT_COL = 1;


// Both Card Movement by Value reports are expected to have 14 source columns.
const REPORT_NUM_COLS = 14;

// Daily RI Audit existing IDs are in corrected column D.
const CORRECTED_REPORT_ID_INDEX = 3;

// Stored row/column count keys.
const DAILY_ROW_COUNT_KEY = "DAILY_RI_AUDIT_OUTPUT_ROWS";
const RTS_ROW_COUNT_KEY = "RTS_OUTPUT_ROWS";
const SQ_ROW_COUNT_KEY = "SQ_OUTPUT_ROWS";
const SQ_COL_COUNT_KEY = "SQ_OUTPUT_COLS";


